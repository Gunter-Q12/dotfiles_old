// Place your key bindings in this file to override the defaultsauto[]
[
    {
        "key": "shift+o",
        "command": ""
    },
    // NAVIGATE POPUPS
    {
        "key": "ctrl+n",
        "command": "selectNextSuggestion",
        "when": "editorTextFocus && suggestWidgetMultipleSuggestions && suggestWidgetVisible"
    },
    {
        "key": "ctrl+p",
        "command": "selectPrevSuggestion",
        "when": "editorTextFocus && suggestWidgetMultipleSuggestions && suggestWidgetVisible"
    },
    {
        "key": "ctrl+n",
        "command": "selectNextCodeAction",
        "when": "codeActionMenuVisible"
    },
    {
        "key": "ctrl+p",
        "command": "selectPrevCodeAction",
        "when": "codeActionMenuVisible"
    },
    {
        "key": "ctrl+n",
        "command": "workbench.action.quickOpenSelectNext",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+p",
        "command": "workbench.action.quickOpenSelectPrevious",
        "when": "inQuickOpen"
    },
    // SCROLL POPUPS
    {
        "key": "q",
        "command": "editor.action.hideHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "h",
        "command": "editor.action.scrollLeftHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "j",
        "command": "editor.action.scrollDownHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "k",
        "command": "editor.action.scrollUpHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "l",
        "command": "editor.action.scrollRightHover",
        "when": "editorHoverFocused"
    },
    {
        "key": "q",
        "command": "editor.action.hideHover",
        "when": "editorHoverFocused"
    },
    // SEARCH
    {
        "key": "ctrl+h",
        "command": "actions.find",
        "when": "editorFocus && editorIsOpen"
    },
    {
        "key": "ctrl+h",
        "command": "closeFindWidget",
        "when": "editorFocus && editorIsOpen && findWidgetVisible"
    },
    {
        "key": "ctrl+shift+h",
        "command": "editor.action.startFindReplaceAction",
        "when": "editorFocus && editorIsOpen"
    },
    {
        "key": "ctrl+n",
        "command": "editor.action.nextMatchFindAction",
        "when": "editorFocus && findWidgetVisible"
    },
    {
        "key": "ctrl+p",
        "command": "editor.action.previousMatchFindAction",
        "when": "editorFocus && findWidgetVisible"
    },
    // EXPLORER
    {
        "key": "ctrl+e",
        "command": "workbench.view.explorer"
    },
    {
        "key": "ctrl+e",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // SOURCE CONTROL
    // {
    //     "key": "ctrl+s",
    //     "command": "workbench.view.scm",
    //     "when": "!scmViewletVisible"
    // },
    // {
    //     "key": "ctrl+s",
    //     "command": "workbench.action.toggleSidebarVisibility",
    //     "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    // },
    // {
    //     "key": "ctrl+alt+s",
    //     "command": "workbench.action.focusSideBar",
    //     "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
    // },
    // {
    //     "key": "ctrl+alt+m",
    //     "command": "workbench.scm.action.focus",
    //     "when": "activeViewlet == 'workbench.view.scm'"
    // },
    // {
    //     "key": "ctrl+alt+enter",
    //     "command": "git.commit",
    //     "when": "activeViewlet == 'workbench.view.scm'"
    // },
    // {
    //     "key": "s",
    //     "command": "git.stage",
    //     "when": "scmProvider == 'git' && scmResourceGroup == 'workingTree'"
    // },
    {
        "key": "n",
        "command": "explorer.newFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "shift+n",
        "command": "explorer.newFolder",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "x",
        "command": "filesExplorer.cut",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "p",
        "command": "filesExplorer.paste",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "d",
        "command": "deleteFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // GIT
    {
        "command": "workbench.view.scm",
        "key": "ctrl+shift+g"
    },
	// FOCUS EDITOR
	{
		"key": "ctrl+i",
		"command": "workbench.action.focusActiveEditorGroup",
		"when": "!editorFocus"
	},
	{
		"key": "ctrl+j",
		"command": "workbench.action.togglePanel"
	},
	{
		"key": "ctrl+k",
		"command": "workbench.action.showCommands"
	},
	{
		"key": "ctrl+h",
		"command": "workbench.action.toggleSidebarVisibility"
	},
	{
		"key": "ctrl+l",
		"command": "workbench.action.toggleAuxiliaryBar"
	},
    {
        "key": "j",
        "command": "list.focusDown",
        "when": "filesExplorerFocus && !inputFocus || referenceSearchVisible && listFocus"
    },
    {
        "key": "k",
        "command": "list.focusUp",
        "when": "filesExplorerFocus && !inputFocus || referenceSearchVisible && listFocus"
    },
    {
        "key": "l",
        "command": "list.select",
        "when": "filesExplorerFocus && !inputFocus || referenceSearchVisible && listFocus"
    },
    {
        "key": "h",
        "command": "list.collapse",
        "when": "filesExplorerFocus && !inputFocus || referenceSearchVisible && listFocus"
    },
    {
        "key": "r",
        "command": "renameFile",
        "when": "filesExplorerFocus && !inputFocus"
    },
    {
        "key": "j",
        "command": "list.focusDown",
        "when": "referenceSearchVisible && listFocus"
    },
    {
        "key": "k",
        "command": "list.focusUp",
        "when": "referenceSearchVisible && listFocus"
    }
]
